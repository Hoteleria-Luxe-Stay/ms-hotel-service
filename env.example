# ============================================================
# hotel-service - DEV environment template
# ------------------------------------------------------------
# Copy this file to .env (in this same folder) and load it
# from your IDE Run Configuration (e.g. EnvFile plugin in IntelliJ).
# Defaults in YAML are PROD-safe; this file overrides for DEV.
# ============================================================

# --- Spring Cloud Config Server ---
CONFIG_IMPORT=optional:configserver:http://localhost:8888
CONFIG_FAIL_FAST=false

# --- Server ---
SERVER_PORT=8082

# --- Eureka discovery ---
EUREKA_URL=http://localhost:8761/eureka

# --- Datasource (MySQL) ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/hotel_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JPA (DEV verbose; YAML defaults are PROD-safe) ---
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# --- JWT (RSA public key) ---
# Same public key emitted by auth-service. PEM single-line with literal \n.
JWT_PUBLIC_KEY=

# --- Auth service (service-to-service via OAuth2 client_credentials) ---
# DEV: auth-service runs locally from IDE on port 8081
AUTH_SERVICE_URL=http://localhost:8081
# These credentials must match what was seeded in auth-service
# (HOTEL_SERVICE_CLIENT_ID / HOTEL_SERVICE_CLIENT_SECRET)
AUTH_SERVICE_CLIENT_ID=
AUTH_SERVICE_CLIENT_SECRET=

# --- CORS (DEV: Angular dev server) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200
